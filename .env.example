# ============================================================================
# .env.example — All required environment variables for Agency-in-a-Box
#
# NEVER commit the actual .env to git.
# In production, inject ALL secrets via Doppler:
#   doppler run -- python -m src
# ============================================================================

# ── PostgreSQL (any provider: Fly Postgres, Neon, Railway, local Docker) ────
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/agency

# ── AI Models ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGEME
GEMINI_API_KEY=AIzaSyCHANGEME

# ── Telegram ─────────────────────────────────────────────────────────────────
# BotFather token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEE
# Your personal chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=123456789
# Arbitrary secret string — set as webhook secret in Telegram API
TELEGRAM_WEBHOOK_SECRET=some-random-secret-min-32-chars

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with: repo, workflow scopes
GITHUB_PAT=ghp_CHANGEME
# GitHub organisation or username to create repos under
GITHUB_ORG=your-github-org
# Default repo to create PRs in (overridden per-job by payload.github_repo)
GITHUB_REPO_DEFAULT=agency-delivery

# ── Fly.io Sandbox ────────────────────────────────────────────────────────────
# Fly API token: https://fly.io/user/personal_access_tokens
FLY_API_TOKEN=fo1_CHANGEME
# Name of the sandbox Fly app (see fly-sandbox/)
FLY_APP_NAME=agency-sandbox

# ── Budget limits (USD) ───────────────────────────────────────────────────────
DAILY_BUDGET_CAP=15.00
PROJECT_BUDGET_CAP=50.00

# ── Firecrawl (optional — only needed for research phase) ────────────────────
# Leave empty to skip live doc fetching (research bundle will be empty)
FIRECRAWL_API_KEY=fc-CHANGEME

# ── Lead Discovery (optional — needed for lead pipeline) ─────────────────────
# Outscraper: Google Maps scraping — https://outscraper.com
OUTSCRAPER_API_KEY=
# Apollo.io: contact enrichment — https://www.apollo.io
APOLLO_API_KEY=
# AnyMail Finder: fallback email finder — https://anymailfinder.com
ANYMAIL_API_KEY=

# ── KvK Validation (optional — Dutch Chamber of Commerce) ────────────────────
# https://developers.kvk.nl
KVK_API_KEY=

# ── Instantly.ai (optional — cold email outreach) ────────────────────────────
# https://developer.instantly.ai
INSTANTLY_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32+ char string used to pepper domain hashes (GDPR dedup)
DOMAIN_PEPPER=change-me-to-a-random-32-char-string

# ── DMZ internal URL (worker → DMZ) ──────────────────────────────────────────
# In production on Fly: http://agency-dmz.internal:8001
# For local dev: http://localhost:8001
DMZ_INTERNAL_URL=http://localhost:8001
